# Property-based tests for the template module — DECLARATIVE SPEC FORM.
#
# The spec-format sibling of `test/template_prop_test.aql`: each property
# is a `PropertySpec` value built by `Test.prop` and run by
# `Test.run-property`. Same properties, expressed as data.
#
# `if` is written all-forward (`if cond [then] [else]`) throughout. Each
# render runs in a fresh sandbox, so these stay cheap per iteration.
#
# Run:
#   aql test/template_prop_spec.aql


import "aql:test"
import "aql:array-util"
import "aql:string-util"
import "./template.aql"


# Tag-free charset so generated text never accidentally opens a tag.
def charset "abcdefghijklmnopqrstuvwxyz0123456789 .,!"


# Print one PropertyResult as a pass/fail line.
def report fn [
  [res:Map] [String] [
    def ok (res get "ok")
    def nm (res get "name")
    if ok
      [`ok   ${nm} (${(res get "runs")} runs)`]
      [`FAIL ${nm}  failing-input: ${(res get "failing-input")}`]
  ]
]


# --- the spec suite, built as data ---------------------------------

def specs [

  # 1. Tag-free text renders unchanged.
  (Test.prop "text-passthrough"
    [ r.string charset (r.int 0 12) ]
    [ var [[s]
        s eq ({engine:'mustache' source:s context:{}} Template.render)
    ] ])

  # 2. A variable round-trips its escape-free value.
  (Test.prop "var-round-trip"
    [ r.string charset (r.int 1 12) ]
    [ var [[s]
        s eq ({engine:'mustache' source:'{{v}}' context:{v:s}} Template.render)
    ] ])

  # 3. Escaping a value wrapped in <…> removes raw angle brackets.
  (Test.prop "escaping-removes-brackets"
    [ r.string charset (r.int 0 8) ]
    [ var [[s]
        def out ({engine:'mustache' source:'{{v}}' context:{v:(StringUtil.concat ["<" s ">"])}} Template.render)
        ((StringUtil.indexof "<" out) lt 0)
    ] ])

  # 4. A list section renders exactly once per element.
  (Test.prop "section-iterates-n-times"
    [ r.int 0 12 ]
    [ var [[n]
        def xs (iota n each [ var [[i] "x" ] ])
        def out ({engine:'mustache' source:'{{#xs}}.{{/xs}}' context:{xs:xs}} Template.render)
        (out size) eq n
    ] ])

  # 5. Two-step compile agrees with the one-shot render.
  (Test.prop "compile-equals-oneshot"
    [ r.string charset (r.int 0 8) ]
    [ var [[s]
        def tpl ({engine:'mustache' source:'[{{v}}]'} Template.compile)
        (tpl Template.render {v:s}) eq ({engine:'mustache' source:'[{{v}}]' context:{v:s}} Template.render)
    ] ])

]


# --- run every spec ------------------------------------------------

def _ (specs each [
  var [[s]
    (s Test.run-property) report
    0
  ]
])


# --- summary -------------------------------------------------------

print ("---")
print (`fail count: ${(Test.fail-count)}`)
0 (Test.fail-count) Assert.equal end
print ("all green")
